{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": { "runtime": "vercel-php@0.9.0" }
    },
    "routes": [
        {
            "src": "/(css|js|assets|vendor|uploads|favicon.ico|mix-manifest.json|robots.txt)(.*)",
            "dest": "/public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "SUPABASE_URL": "https://tlcmkcamympklneqvqsn.supabase.co",
        "SUPABASE_SERVICE_KEY": "sb_publishable_rUE5ftoRs5mdkOf-o26c1w_lXq7cSWi",
        "SUPABASE_BUCKET": "uploads"
    }
